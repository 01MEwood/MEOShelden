# ============================================
# MEOS:HELDEN — Umgebungsvariablen
# Kopiere diese Datei als .env und fülle die Werte
# ============================================

# ── Database (shared PostgreSQL — Supabase or VPS) ──
DATABASE_URL=postgresql://postgres:PASSWORD@HOST:5432/meos_helden?schema=public

# ── OpenAI ──
OPENAI_API_KEY=sk-...

# ── DataForSEO (gleiche Credentials wie MEOS:SEO) ──
DATAFORSEO_LOGIN=your@email.com
DATAFORSEO_PASSWORD=your-password

# ── Google Search Console (optional, JSON-encoded service account) ──
# GSC_CREDENTIALS={"type":"service_account","project_id":"...","private_key":"..."}
GSC_SITE_URL=https://schreinerhelden.de/

# ── Auth ──
JWT_SECRET=meos-helden-2026-geheim

# ── Frontend URL (for CORS) ──
FRONTEND_URL=https://helden.meosapp.de

# ── WordPress REST API (für Direct Push) ──
WP_URL=https://schreinerhelden.de
WP_USER=mario
WP_APP_PASSWORD=xxxx-xxxx-xxxx-xxxx

# ── Server ──
PORT=4200
